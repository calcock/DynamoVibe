{
  "name": "dynamite",
  "version": "0.1.0",
  "description": "Cross-platform desktop GUI client for Amazon DynamoDB",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:local": "node scripts/seed-local.mjs",
    "pack:win": "npm run build && electron-builder --win",
    "pack:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.620.0",
    "@aws-sdk/credential-providers": "^3.620.0",
    "@aws-sdk/lib-dynamodb": "^3.620.0",
    "@aws-sdk/util-dynamodb": "^3.620.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/core": "^7.11.0",
    "@mantine/hooks": "^7.11.0",
    "@mantine/modals": "^7.11.0",
    "@mantine/notifications": "^7.11.0",
    "@monaco-editor/react": "^4.6.0",
    "@tabler/icons-react": "^3.11.0",
    "@tanstack/react-query": "^5.51.0",
    "@tanstack/react-table": "^8.19.0",
    "@tanstack/react-virtual": "^3.8.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "aws-sdk-client-mock": "^4.0.0",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "monaco-editor": "^0.50.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0",
    "zustand": "^4.5.0"
  }
}
